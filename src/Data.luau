const HttpService = game:GetService("HttpService")

const MAX_ATTEMPTS = 8
const RETRY_DELAY = 0.1

const function getEquivalentTableValue(container: { [any]: any }, key: any): any
	const value = container[key]
	if value ~= nil then
		return value
	end

	if typeof(key) == "number" then
		return container[tostring(key)]
	end
	if typeof(key) == "string" then
		const numericKey = tonumber(key)
		if numericKey ~= nil then
			return container[numericKey]
		end
	end

	return nil
end

const function valuesEqual(left: any, right: any): boolean
	if typeof(left) ~= typeof(right) then
		return false
	end
	if typeof(left) ~= "table" then
		return left == right
	end

	local leftCount = 0
	for key, value in left do
		leftCount += 1
		const rightValue = getEquivalentTableValue(right, key)
		if rightValue == nil or not valuesEqual(value, rightValue) then
			return false
		end
	end

	local rightCount = 0
	for _ in right do
		rightCount += 1
	end
	return leftCount == rightCount
end

const function readRaw(plugin: Plugin, key: string): (boolean, any)
	local readSucceeded = false
	for attempt = 1, MAX_ATTEMPTS do
		const success, value = pcall(function()
			return plugin:GetSetting(key)
		end)
		if success then
			readSucceeded = true
		end
		if success and value ~= nil then
			return true, value
		end

		if attempt < MAX_ATTEMPTS then
			task.wait(RETRY_DELAY)
		end
	end

	return readSucceeded, nil
end

const function load(plugin: Plugin, key: string, fallback: any): any
	const readSucceeded, saved = readRaw(plugin, key)
	if not readSucceeded then
		error(`CodeKit could not read saved data for {key} after {MAX_ATTEMPTS} attempts.`)
	end
	if saved == nil then
		return fallback
	end
	if typeof(saved) == "table" then
		return saved
	end
	if typeof(saved) ~= "string" then
		warn(`CodeKit found an invalid saved value for {key}; using defaults.`)
		return fallback
	end

	const success, decoded = pcall(function()
		return HttpService:JSONDecode(saved)
	end)
	if not success then
		warn(`CodeKit could not decode saved data for {key}; using defaults.`)
		return fallback
	end
	return decoded
end

const function save(plugin: Plugin, key: string, value: any)
	for attempt = 1, MAX_ATTEMPTS do
		const success = pcall(function()
			plugin:SetSetting(key, value)
		end)
		if success then
			task.wait(RETRY_DELAY * attempt)
			const readSuccess, saved = readRaw(plugin, key)
			if readSuccess and valuesEqual(saved, value) then
				return
			end
		end

		if attempt < MAX_ATTEMPTS then
			task.wait(RETRY_DELAY)
		end
	end

	error(`CodeKit could not verify saved data for {key} after {MAX_ATTEMPTS} attempts.`)
end

const function getWorkspaceModule(name: string): ModuleScript?
	const existing = game:FindFirstChild(name)
	if existing == nil or not existing:IsA("ModuleScript") then
		return nil
	end
	return existing
end

const function getOrCreateWorkspaceModule(name: string): ModuleScript
	const existing = getWorkspaceModule(name)
	if existing ~= nil then
		return existing
	end

	const module = Instance.new("ModuleScript")
	module.Name = name
	module.Parent = game
	return module
end

const function getLongStringDelimiter(text: string): (string, string)
	local equals = ""
	while string.find(text, `]{equals}]`, 1, true) ~= nil do
		equals ..= "="
	end

	return `[{equals}[`, `]{equals}]`
end

const function encodeWorkspaceSource(comment: string, value: any): string
	const payload = HttpService:JSONEncode(value)
	const openDelimiter, closeDelimiter = getLongStringDelimiter(payload)
	return table.concat({
		"-- generated by CodeKit",
		`-- {comment}`,
		`return game:GetService("HttpService"):JSONDecode({openDelimiter}{payload}{closeDelimiter})`,
	}, "\n")
end

const function decodeWorkspaceSource(source: string): any?
	const openStart, openEnd, equals = string.find(source, "%[(=*)%[")
	if openStart == nil or openEnd == nil or equals == nil then
		return nil
	end

	const closeDelimiter = `]{equals}]`
	const closeStart = string.find(source, closeDelimiter, openEnd + 1, true)
	if closeStart == nil then
		return nil
	end

	const payload = string.sub(source, openEnd + 1, closeStart - 1)
	const success, decoded = pcall(function()
		return HttpService:JSONDecode(payload)
	end)
	if not success then
		return nil
	end
	return decoded
end

const function loadWorkspace(name: string, fallback: any): any
	const module = getWorkspaceModule(name)
	if module == nil then
		return fallback
	end

	const decoded = decodeWorkspaceSource(module.Source)
	if decoded == nil then
		warn(`CodeKit could not decode workspace data in {name}; using defaults.`)
		return fallback
	end
	return decoded
end

const function saveWorkspace(name: string, comment: string, value: any)
	const source = encodeWorkspaceSource(comment, value)
	const module = getOrCreateWorkspaceModule(name)
	module.Source = source
	if module.Source ~= source then
		error(`CodeKit could not verify workspace data for {name}.`)
	end
end

const function deleteWorkspace(name: string)
	const module = getWorkspaceModule(name)
	if module ~= nil then
		module:Destroy()
	end
end

return {
	load = load,
	save = save,
	loadWorkspace = loadWorkspace,
	saveWorkspace = saveWorkspace,
	deleteWorkspace = deleteWorkspace,
}
