export type ThemeColor = { number }

export type Theme = {
	name: string,
	colors: { [string]: ThemeColor },
}

type ThemePalette = {
	background: ThemeColor,
	foreground: ThemeColor,
	selection: ThemeColor,
	find: ThemeColor,
	line: ThemeColor,
	ruler: ThemeColor,
	comment: ThemeColor,
	red: ThemeColor,
	orange: ThemeColor,
	yellow: ThemeColor,
	green: ThemeColor,
	cyan: ThemeColor,
	blue: ThemeColor,
	purple: ThemeColor,
}

const function createTheme(name: string, palette: ThemePalette): Theme
	return {
		name = name,
		colors = {
			["Background Color"] = palette.background,
			["Selection Color"] = palette.foreground,
			["Selection Background Color"] = palette.selection,
			["Error Color"] = palette.red,
			["Warning Color"] = palette.orange,
			["Find Selection Background Color"] = palette.find,
			["Matching Word Background Color"] = palette.selection,
			["Whitespace Color"] = palette.comment,
			["Current Line Highlight Color"] = palette.line,
			["Ruler Color"] = palette.ruler,
			["Bracket Color"] = palette.foreground,
			["Text Color"] = palette.foreground,
			["Operator Color"] = palette.foreground,
			["Number Color"] = palette.orange,
			["String Color"] = palette.green,
			["Comment Color"] = palette.comment,
			["Bool Color"] = palette.orange,
			["\"nil\" Color"] = palette.orange,
			["Function Name Color"] = palette.blue,
			["\"function\" Color"] = palette.purple,
			["\"local\" Color"] = palette.purple,
			["\"self\" Color"] = palette.yellow,
			["Luau Keyword Color"] = palette.red,
			["Keyword Color"] = palette.purple,
			["Built-in Function Color"] = palette.cyan,
			["\"TODO\" Color"] = palette.red,
			["Method Color"] = palette.blue,
			["Property Color"] = palette.yellow,
		},
	}
end

