const HttpService = game:GetService("HttpService")
const Types = require("./Types")

const GLOBAL_SETTING_KEY = "IvadsAutoImportSettings"
const LEGACY_SETTING_KEY = "AutoImportSettings"
const WORKSPACE_SETTINGS_NAME = "_IAI_SETTINGS"

const DEFAULT_SETTINGS: Types.Settings = {
	enabled = true,
	stringRequires = false,
	requireMode = "global",
	keyword = "const",
	prefix = ":",
	autoServices = true,
	additionalServices = {},
	ignoredNames = { "_Index", "_index", "node_modules", "include" },
	overrideWorkspaceSettings = false,
}

const function cloneList(list: { string }): { string }
	const cloned = {}
	for _, value in list do
		table.insert(cloned, value)
	end

	return cloned
end

const function normalizeList(value: any, fallback: { string }): { string }
	if typeof(value) ~= "table" then
		return cloneList(fallback)
	end

	const normalized = {}
	for _, item in value do
		if typeof(item) == "string" and item ~= "" then
			table.insert(normalized, item)
		end
	end

	return normalized
end

const function normalizeSettings(value: any): Types.Settings
	if typeof(value) ~= "table" then
		value = {}
	end

	local requireMode = value.requireMode
	if requireMode ~= "local" and requireMode ~= "global" then
		requireMode = DEFAULT_SETTINGS.requireMode
	end
	local keyword = value.keyword
	if keyword ~= "local" and keyword ~= "const" then
		keyword = DEFAULT_SETTINGS.keyword
	end

	return {
		enabled = value.enabled ~= false,
		stringRequires = value.stringRequires == true,
		requireMode = requireMode,
		keyword = keyword,
		prefix = if typeof(value.prefix) == "string" then value.prefix else DEFAULT_SETTINGS.prefix,
		autoServices = value.autoServices ~= false,
		additionalServices = normalizeList(value.additionalServices, DEFAULT_SETTINGS.additionalServices),
		ignoredNames = normalizeList(value.ignoredNames, DEFAULT_SETTINGS.ignoredNames),
		overrideWorkspaceSettings = value.overrideWorkspaceSettings == true,
	}
end

const function getWorkspaceModule(): ModuleScript?
	const existing = game:FindFirstChild(WORKSPACE_SETTINGS_NAME)
	if existing == nil then
		return nil
	end
	if not existing:IsA("ModuleScript") then
		return nil
	end

	return existing
end

const function getOrCreateWorkspaceModule(): ModuleScript
	const existing = getWorkspaceModule()
	if existing ~= nil then
		return existing
	end

	const module = Instance.new("ModuleScript")
	module.Name = WORKSPACE_SETTINGS_NAME
	module.Parent = game
	return module
end

const function getLongStringDelimiter(text: string): (string, string)
	local equals = ""
	while string.find(text, `]{equals}]`, 1, true) ~= nil do
		equals ..= "="
	end

	return `[{equals}[`, `]{equals}]`
end

const function encodeWorkspaceSource(settings: Types.Settings): string
	const payload = HttpService:JSONEncode(settings)
	const openDelimiter, closeDelimiter = getLongStringDelimiter(payload)
	return table.concat({
		"-- generated by ivad's Auto Import",
		"-- edit from the plugin settings window",
		`return game:GetService("HttpService"):JSONDecode({openDelimiter}{payload}{closeDelimiter})`,
	}, "\n")
end

const function decodeWorkspaceSource(source: string): Types.Settings?
	const openStart, openEnd, equals = string.find(source, "%[(=*)%[")
	if openStart == nil or openEnd == nil or equals == nil then
		return nil
	end
	const closeDelimiter = `]{equals}]`
	const closeStart = string.find(source, closeDelimiter, openEnd + 1, true)
	if closeStart == nil then
		return nil
	end
	const payload = string.sub(source, openEnd + 1, closeStart - 1)

	local decoded
	local ok = pcall(function()
		decoded = HttpService:JSONDecode(payload)
	end)
	if not ok then
		return nil
	end

	return normalizeSettings(decoded)
end

const function loadWorkspaceSettings(): Types.Settings?
	const module = getWorkspaceModule()
	if module == nil then
		return nil
	end

	return decodeWorkspaceSource(module.Source)
end

const function saveWorkspaceSettings(settings: Types.Settings)
	const module = getOrCreateWorkspaceModule()
	module.Source = encodeWorkspaceSource(settings)
end

const function create(plugin: Plugin)
	local globalSettings = normalizeSettings(plugin:GetSetting(GLOBAL_SETTING_KEY) or plugin:GetSetting(LEGACY_SETTING_KEY))
	local workspaceSettings = loadWorkspaceSettings()
	const changed = Instance.new("BindableEvent")

	const function getEffectiveSettings(): Types.Settings
		if globalSettings.overrideWorkspaceSettings then
			return globalSettings
		end
		return workspaceSettings or globalSettings
	end

	const function fireChanged()
		changed:Fire(getEffectiveSettings())
	end

	const function saveGlobal()
		plugin:SetSetting(GLOBAL_SETTING_KEY, globalSettings)
		fireChanged()
	end

	const function saveWorkspace()
		workspaceSettings = normalizeSettings(workspaceSettings)
		saveWorkspaceSettings(workspaceSettings :: Types.Settings)
		fireChanged()
	end

	return {
		changed = changed.Event,
		get = getEffectiveSettings,
		getGlobal = function(): Types.Settings
			return globalSettings
		end,
		getWorkspace = function(): Types.Settings
			if workspaceSettings == nil then
				workspaceSettings = normalizeSettings(globalSettings)
				if workspaceSettings then
					workspaceSettings.overrideWorkspaceSettings = false
				end
			end
			return workspaceSettings :: Types.Settings
		end,
		hasWorkspace = function(): boolean
			return workspaceSettings ~= nil
		end,
		update = function(scope: Types.SettingsScope, key: string, value: any)
			if scope == "global" then
				globalSettings[key] = value
				globalSettings = normalizeSettings(globalSettings)
				saveGlobal()
			else
				const settings = if workspaceSettings == nil then normalizeSettings(globalSettings) else workspaceSettings
				settings[key] = value
				settings.overrideWorkspaceSettings = false
				workspaceSettings = normalizeSettings(settings)
				saveWorkspace()
			end
		end,
		reset = function(scope: Types.SettingsScope)
			if scope == "global" then
				globalSettings = normalizeSettings(DEFAULT_SETTINGS)
				saveGlobal()
			else
				workspaceSettings = normalizeSettings(DEFAULT_SETTINGS)
				if workspaceSettings then
					workspaceSettings.overrideWorkspaceSettings = false
					saveWorkspace()
				end
			end
		end,
		refreshWorkspace = function()
			workspaceSettings = loadWorkspaceSettings()
			fireChanged()
		end,
		destroy = function()
			changed:Destroy()
		end,
	}
end

return {
	create = create,
	DEFAULT_SETTINGS = DEFAULT_SETTINGS,
	WORKSPACE_SETTINGS_NAME = WORKSPACE_SETTINGS_NAME,
}
